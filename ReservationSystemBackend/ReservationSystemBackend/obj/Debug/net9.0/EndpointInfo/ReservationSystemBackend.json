{
  "openapi": "3.0.4",
  "info": {
    "title": "ReservationSystemBackend",
    "version": "1.0"
  },
  "paths": {
    "/api/Hotel/CreateHotel": {
      "post": {
        "tags": [
          "Hotel"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHotelDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHotelDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHotelDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Hotel/GetAllHotels": {
      "get": {
        "tags": [
          "Hotel"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Reservation/GetAvaliableRooms": {
      "get": {
        "tags": [
          "Reservation"
        ],
        "parameters": [
          {
            "name": "topicId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "investorId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "presenterId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Reservation/AddReservation": {
      "post": {
        "tags": [
          "Reservation"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservationDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservationDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservationDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Topic/GettingAllTopics": {
      "get": {
        "tags": [
          "Topic"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/User/CreateUser": {
      "post": {
        "tags": [
          "User"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/User/GetMatchingPresenter": {
      "get": {
        "tags": [
          "User"
        ],
        "parameters": [
          {
            "name": "topic",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "investor",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/User/GettingAllInvestors": {
      "get": {
        "tags": [
          "User"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/User/GettingAllPresenters": {
      "get": {
        "tags": [
          "User"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateHotelDTO": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "rooms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoomDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateReservationDTO": {
        "required": [
          "investorId",
          "presenterId",
          "roomSlotId",
          "topicId"
        ],
        "type": "object",
        "properties": {
          "topicId": {
            "type": "integer",
            "format": "int32"
          },
          "investorId": {
            "type": "integer",
            "format": "int32"
          },
          "presenterId": {
            "type": "integer",
            "format": "int32"
          },
          "roomSlotId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateUserDTO": {
        "required": [
          "mobile",
          "name",
          "userType"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "mobile": {
            "minLength": 1,
            "type": "string"
          },
          "userType": {
            "type": "integer",
            "format": "int32"
          },
          "userTopicAvaliabilityDTOs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserTopicAvaliabilityDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RoomDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "roomSlots": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoomSlotDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RoomSlotDTO": {
        "type": "object",
        "properties": {
          "startTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "UserTopicAvaliabilityDTO": {
        "required": [
          "avaliabilityFrom",
          "avaliabilityTo",
          "topicId"
        ],
        "type": "object",
        "properties": {
          "topicId": {
            "type": "integer",
            "format": "int32"
          },
          "avaliabilityFrom": {
            "type": "string",
            "format": "date-time"
          },
          "avaliabilityTo": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  }
}